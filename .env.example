# ─────────────────────────────────────────────────────────────────────────────
# Alumère — configurazione di PRODUZIONE (deploy pubblico).
# Copia questo file in `.env` e compila i valori REALI:   cp .env.example .env
# `.env` è git-ignorato e NON entra nell'immagine (.dockerignore): tienilo solo sul server.
# Lo leggono sia `docker compose` (per il dominio di Caddy) sia il container dell'app.
# ─────────────────────────────────────────────────────────────────────────────

# ── Dominio pubblico e HTTPS ────────────────────────────────────────────────
# Dominio su cui gira l'app. Deve avere un record DNS A → IP del server.
# Caddy ottiene automaticamente il certificato TLS per questo dominio.
PUBLIC_DOMAIN=docs.example.com
# URL base assoluto usato nei magic-link via email. Deve combaciare con PUBLIC_DOMAIN, in https.
PUBLIC_BASE_URL=https://docs.example.com

# ── Gate di accesso (chi può entrare) ───────────────────────────────────────
# Solo le email di QUESTO dominio possono richiedere un accesso. VUOTO = qualsiasi (solo dev!).
ALLOWED_EMAIL_DOMAIN=example.com
# Minuti di validità del magic-link.
LOGIN_TOKEN_TTL_MIN=15

# ── Cookie di sessione ──────────────────────────────────────────────────────
# Dietro HTTPS DEVE valere 1 (cookie marcato Secure).
COOKIE_SECURE=1
# App dietro reverse proxy: 1 = fìdati del primo hop (Caddy) per leggere l'IP reale del client
# (serve al rate-limit per-IP). Lascialo 1 in questo setup.
TRUST_PROXY=1
# Segreto per firmare i cookie di sessione. Generane uno TUO:   openssl rand -hex 32
# Se lo lasci vuoto, l'app ne persiste uno su disco nel volume dati (funziona lo stesso,
# ma impostarlo qui lo rende esplicito e ruotabile).
SESSION_SECRET=

# ── SMTP (invio dei magic-link) ─────────────────────────────────────────────
# Esempio: casella privateemail (Namecheap). Usa una casella REALE del tuo dominio per una
# buona deliverability, e configura SPF/DKIM sul dominio (altrimenti le mail finiscono in spam).
# Se lasci SMTP_HOST vuoto, l'app NON invia: stampa il link nei log (solo per test).
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=
# Mittente mostrato nelle email (default = SMTP_USER).
SMTP_FROM=noreply@example.com
